---
import { ClientRouter } from 'astro:transitions';
import { THEMES } from '../data/themes';
import '../styles/global.css';

interface Props {
  /** terminal path label, e.g. "~", "~/projects", "~/projects/hexa" */
  path?: string;
  /** which nav item is active */
  active?: 'home' | 'projects' | 'writing' | 'about' | 'resume' | 'contact';
  title?: string;
  description?: string;
}

const {
  path = '~',
  active = 'home',
  title = 'Camden Brown — Founding Engineer & Full-Stack Developer',
  description = 'Camden Brown — founding engineer at Sympliact. Full-stack TypeScript — Angular · Node · Rails. Full-stack products that ship and scale, greenfield to production; consulting across health-tech, government, and B2B SaaS.',
} = Astro.props;

// Absolute URLs for social/meta (Astro.site = https://camden-brown.github.io)
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/og.png', Astro.site).href;

const nav = [
  { id: 'home', label: 'home', href: '/' },
  { id: 'projects', label: 'projects', href: '/projects/' },
  { id: 'writing', label: 'writing', href: '/writing/' },
  { id: 'about', label: 'about', href: '/about/' },
  { id: 'resume', label: 'resume', href: '/resume/' },
  { id: 'contact', label: 'contact', href: '/contact/' },
] as const;
---

<!DOCTYPE html>
<html lang="en" data-theme="dracula">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Camden Brown" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicons/favicon-32x32.png" />
    <link rel="apple-touch-icon" href="/favicons/apple-touch-icon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <ClientRouter />

    {/* Apply the persisted theme before first paint to avoid a flash.
        Must be inline in <head>; all other client behaviour lives in ui.ts. */}
    <script is:inline>
      try {
        var ids = ['dracula', 'nord', 'gruvbox', 'tokyo-night', 'solarized'];
        var t = localStorage.getItem('theme');
        document.documentElement.setAttribute('data-theme', ids.indexOf(t) >= 0 ? t : 'dracula');
      } catch (e) {}
    </script>
  </head>
  <body>
    <div class="window">
      <!-- window chrome -->
      <div class="titlebar">
        <span class="dot dot-r"></span>
        <span class="dot dot-y"></span>
        <span class="dot dot-g"></span>
        <span class="titlebar-path">camden@portfolio <span class="sep">&mdash;</span> {path}</span>
        <nav class="nav">
          {
            nav.map((item) => (
              <a
                class:list={['navlink', { active: active === item.id }]}
                href={item.href}
              >
                {item.label}
              </a>
            ))
          }
          <div class="theme-menu">
            <button
              class="theme-btn"
              id="theme-btn"
              type="button"
              aria-haspopup="true"
              aria-expanded="false"
              aria-label="Choose color theme"
            >
              <span class="swatch"></span>
              <span class="theme-btn-label">theme</span>
              <span class="caret">&#9662;</span>
            </button>
            <ul class="theme-list" id="theme-list" role="menu" hidden>
              {
                THEMES.map((t) => (
                  <li role="none">
                    <button
                      type="button"
                      role="menuitemradio"
                      class="theme-opt"
                      data-theme-id={t.id}
                      aria-checked="false"
                    >
                      <span class="swatch" style={`background:${t.swatch}`} />
                      <span class="theme-opt-name">{t.label}</span>
                      <span class="check">&#10003;</span>
                    </button>
                  </li>
                ))
              }
            </ul>
          </div>
        </nav>
      </div>

      <!-- body -->
      <div class="body">
        <slot />
      </div>

      <!-- status bar -->
      <div class="statusbar">
        <span class="branch">&#9095; main</span>
        <span>✓ Playwright QA</span>
        <span>Angular · TS · Node</span>
        <span class="spacer">© 2026 Camden Brown</span>
      </div>
    </div>

    <script>
      import { applyTheme, initUI } from '../scripts/ui';
      // Re-assert the theme the instant the DOM swaps (before paint) to avoid a
      // flash, then wire the toggle + favicon once the page is fully ready.
      document.addEventListener('astro:after-swap', applyTheme);
      document.addEventListener('astro:page-load', initUI);
    </script>
  </body>
</html>
