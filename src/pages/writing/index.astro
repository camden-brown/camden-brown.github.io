---
import Shell from '../../layouts/Shell.astro';
import Prompt from '../../components/Prompt.astro';
import { getSortedPosts, fmtDate } from '../../lib/posts';

const posts = await getSortedPosts();
---

<Shell path="~/writing" active="writing" title="Writing — Camden Brown">
  <Prompt cmd="cat ./writing/*" />
  <div class="page-title">Writing &amp; deep-dives</div>
  <div class="page-intro">
    How I think about building software — system-design deep-dives, architecture
    tradeoffs, and notes from the work across a long-running founding-engineer role.
  </div>

  <div class="rows--writing">
    {
      posts.map((p) => (
        <a class="wrow writing-row" href={`/writing/${p.id}/`}>
          <span class="wr-date">{fmtDate(p.data.date)}</span>
          <div>
            <div class="wr-title">
              {p.data.title}
              {p.data.categories[0] && <span class="wr-cat">{p.data.categories[0]}</span>}
            </div>
            <div class="wr-desc">{p.data.description}</div>
            <div class="wr-read">read →</div>
          </div>
        </a>
      ))
    }
  </div>
</Shell>
