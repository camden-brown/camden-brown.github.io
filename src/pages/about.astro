---
import Shell from '../layouts/Shell.astro';
import Prompt from '../components/Prompt.astro';
import { skills } from '../data/portfolio';
---

<Shell path="~/about" active="about" title="About — Camden Brown">
  <Prompt cmd="cat about.md" />
  <div class="about-grid">
    <div>
      <div class="page-title flush">About</div>
      <p class="copy copy--lg">
        I’m a founding engineer and full-stack developer — Angular, TypeScript, and Rails. For the
        last seven years I’ve been the founding engineer at Sympliact, architecting a healthcare
        platform from an empty repo to production Practice &amp; Patient PWAs that support 500+ weekly
        patient sign-ups and 200+ active staff.
      </p>
      <p class="copy copy--lg">
        Alongside Sympliact I consult across health-tech, government, and B2B SaaS — a Rails + Angular
        platform automating $1M+ in shipment operations (Hexa), an air-gapped generative-AI chat
        platform for a government client, and a Figma-style email-template studio for a Fortune 500
        insurer (Symetra). Earlier, I led an 8-engineer team at Metova re-architecting the SiriusXM
        web player from AngularJS to Angular. I care about clean architecture, safe release cadence,
        and shipping fast without breaking trust.
      </p>
      <div class="label mt-24">## CURRENTLY</div>
      <p class="copy">
        Building at Sympliact, consulting on frontend architecture and AI product UX, and tinkering
        with agentic LLM tooling — recently a Claude-powered trading bot. Tennessee Tech alum, based
        in Cookeville, Tennessee · remote.
      </p>
    </div>
    <div>
      <img class="portrait" src="/avatar.jpg" alt="Camden Brown" />
      <div class="label mt-18">## TOOLKIT</div>
      <div class="chips mt-12">
        {skills.map((s) => <span class="chip">{s}</span>)}
      </div>
    </div>
  </div>
</Shell>
