---
import Shell from '../../layouts/Shell.astro';
import { projects } from '../../data/portfolio';

export function getStaticPaths() {
  return projects.map((p, i) => {
    const prev = projects[(i - 1 + projects.length) % projects.length];
    const next = projects[(i + 1) % projects.length];
    return { params: { id: p.id }, props: { project: p, prev, next } };
  });
}

const { project: cp, prev, next } = Astro.props;
---

<Shell path={`~/projects/${cp.id}`} active="projects" title={`${cp.name} — Camden Brown`} description={cp.thesis}>
  <a href="/projects/" class="prompt">
    <span class="user">camden@portfolio</span> ~/projects % <span class="cmd">cat {cp.id}.md</span>
  </a>

  <div class="case-head">
    <div>
      <div class="case-name">{cp.name}</div>
      <div class="case-meta">
        {cp.role} &nbsp;<span class="case-sep">|</span>&nbsp; {cp.dates} &nbsp;<span class="case-sep">|</span>&nbsp; {cp.category}
      </div>
    </div>
    <a href="/projects/" class="btn btn--sm">← all projects</a>
  </div>

  <div class="case-thesis">{cp.thesis}</div>

  <div class="metrics-grid" data-cols={String(cp.metrics.length)}>
    {
      cp.metrics.map((m) => (
        <div class="tile">
          <div class="tile-n">{m.n}</div>
          <div class="tile-label">{m.label}</div>
        </div>
      ))
    }
  </div>

  {
    cp.overview && (
      <div class="section">
        <div class="label">## OVERVIEW</div>
        <p class="copy readable">{cp.overview}</p>
      </div>
    )
  }

  <div class="two-col">
    <div>
      <div class="label">## CONTEXT</div>
      <p class="copy">{cp.context}</p>
    </div>
    <div>
      <div class="label">## WHAT I BUILT</div>
      <ul class="bullets">
        {
          cp.built.map((b) => (
            <li class="bullet"><span class="bullet-mark">&#9656;</span><span>{b}</span></li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="section">
    <div class="label">## SCREENS</div>
    {
      cp.gallery && cp.shotDir ? (
        <div class="gallery">
          {cp.gallery.map((g, i) => (
            <button
              type="button"
              class="gallery-item"
              data-full={`/${cp.shotDir}/${g.src}`}
              data-caption={g.caption}
              data-index={i}
              aria-label={`View ${g.caption}`}
            >
              <img src={`/${cp.shotDir}/${g.src}`} alt={g.caption} loading="lazy" />
              <span class="gallery-cap">{g.caption}</span>
            </button>
          ))}
        </div>
      ) : (
        <div class="screens-grid">
          {cp.shotDir ? (
            <img class="shot" src={`/${cp.shotDir}/${cp.shotA}`} alt={`${cp.name} screenshot`} loading="lazy" />
          ) : (
            <div class="shot">[ {cp.shotA} ]</div>
          )}
          {cp.shotDir ? (
            <img class="shot" src={`/${cp.shotDir}/${cp.shotB}`} alt={`${cp.name} screenshot`} loading="lazy" />
          ) : (
            <div class="shot">[ {cp.shotB} ]</div>
          )}
        </div>
      )
    }
  </div>

  {
    cp.engineering && (
      <div class="section">
        <div class="label">## ENGINEERING</div>
        <ul class="bullets readable">
          {cp.engineering.map((e) => (
            <li class="bullet"><span class="bullet-mark">&#9656;</span><span>{e}</span></li>
          ))}
        </ul>
      </div>
    )
  }

  <div class="stack-row">
    <span class="label">## STACK</span>
    <div class="chips">
      {cp.stack.map((s) => <span class="chip">{s}</span>)}
    </div>
  </div>

  <div class="pager">
    <a href={`/projects/${prev.id}/`} class="lrow">← {prev.name}</a>
    <a href={`/projects/${next.id}/`} class="lrow">{next.name} →</a>
  </div>

  {
    cp.gallery && cp.shotDir && (
      <div class="lightbox" id="lightbox" hidden>
        <button class="lb-close" type="button" aria-label="Close">&#10005;</button>
        <button class="lb-prev" type="button" aria-label="Previous">&#8249;</button>
        <img class="lb-img" alt="" />
        <button class="lb-next" type="button" aria-label="Next">&#8250;</button>
        <div class="lb-cap" />
      </div>
    )
  }
</Shell>
